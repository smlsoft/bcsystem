NODE_ENV=development
PORT=8088
DATABASE_URL=postgres://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:5432/bccashier_audit_log
POSTGRES_PASSWORD=CHANGE_ME

# Comma-separated device/app API keys. Flutter apps send: Authorization: Bearer <key>
AUDIT_API_KEYS=CHANGE_ME

# Telegram bot token from BotFather. Optional until Telegram is enabled.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME

# Restrict Telegram usage to these chat ids. Empty means deny all Telegram analysis.
TELEGRAM_ALLOWED_CHAT_IDS=

# Cloudflare named tunnel token for bccashieraudit.
# Get it from Cloudflare Zero Trust > Networks > Tunnels > bccashieraudit > Install and run connector.
CLOUDFLARED_TOKEN=

# OpenAI-compatible API config. Keep this only on the service, never in Flutter apps.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Default analysis bounds
DEFAULT_TIMEZONE=Asia/Bangkok
MAX_ANALYSIS_ROWS=10000
